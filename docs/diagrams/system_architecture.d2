# TI-Radar v3.0 — Systemarchitektur

direction: right

# ============================================================
# EXTERNAL SOURCES (left)
# ============================================================
external: "Externe\nDatenquellen" {
  style: {
    fill: "#1A1A1A"
    stroke: "#78909C"
    font-color: "#B0BEC5"
    border-radius: 10
    stroke-dash: 5
    stroke-width: 2
    font-size: 22
  }
  grid-rows: 4
  grid-columns: 1
  grid-gap: 2

  a: "EPO DOCDB" {
    style: { fill: "#2A2A2A"; stroke: "#90A4AE"; font-color: "#CFD8DC"; border-radius: 4; font-size: 18 }
  }
  b: "EU CORDIS" {
    style: { fill: "#2A2A2A"; stroke: "#90A4AE"; font-color: "#CFD8DC"; border-radius: 4; font-size: 18 }
  }
  c: "OpenAIRE" {
    style: { fill: "#2A2A2A"; stroke: "#90A4AE"; font-color: "#CFD8DC"; border-radius: 4; font-size: 18 }
  }
  d: "Semantic Scholar" {
    style: { fill: "#2A2A2A"; stroke: "#90A4AE"; font-color: "#CFD8DC"; border-radius: 4; font-size: 18 }
  }
}

# ============================================================
# DATABASE
# ============================================================
database: "DATENBANK\nPostgreSQL 17 | 6 Schemas | ~590 GB" {
  style: {
    fill: "#2E1A00"
    stroke: "#FF9800"
    font-color: "#FFE0B2"
    border-radius: 10
    stroke-width: 2
    font-size: 22
    multiple: true
  }
  grid-rows: 3
  grid-columns: 2
  grid-gap: 2

  a: "patent" {
    style: { fill: "#4D3200"; stroke: "#FFB74D"; font-color: "#FFE0B2"; border-radius: 4; font-size: 18 }
  }
  b: "cordis" {
    style: { fill: "#4D3200"; stroke: "#FFB74D"; font-color: "#FFE0B2"; border-radius: 4; font-size: 18 }
  }
  c: "research" {
    style: { fill: "#4D3200"; stroke: "#FFB74D"; font-color: "#FFE0B2"; border-radius: 4; font-size: 18 }
  }
  d: "entity" {
    style: { fill: "#4D3200"; stroke: "#FFB74D"; font-color: "#FFE0B2"; border-radius: 4; font-size: 18 }
  }
  e: "cross" {
    style: { fill: "#4D3200"; stroke: "#FFB74D"; font-color: "#FFE0B2"; border-radius: 4; font-size: 18 }
  }
  f: "export" {
    style: { fill: "#4D3200"; stroke: "#FFB74D"; font-color: "#FFE0B2"; border-radius: 4; font-size: 18 }
  }
}

