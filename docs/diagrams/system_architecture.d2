# ============================================================
# API GATEWAY
# ============================================================
gateway: "API GATEWAY\nFastAPI | REST/JSON" {
  style: {
    fill: "#0D2818"
    stroke: "#4CAF50"
    font-color: "#C8E6C9"
    border-radius: 10
    stroke-width: 2
    font-size: 22
  }
  grid-rows: 3
  grid-columns: 1
  grid-gap: 2

  a: "Orchestrator" {
    style: { fill: "#1A3D28"; stroke: "#66BB6A"; font-color: "#A5D6A7"; border-radius: 4; font-size: 18 }
  }
  b: "Response Cache" {
    style: { fill: "#1A3D28"; stroke: "#66BB6A"; font-color: "#A5D6A7"; border-radius: 4; font-size: 18 }
  }
  c: "CORS / Rate Limit" {
    style: { fill: "#1A3D28"; stroke: "#66BB6A"; font-color: "#A5D6A7"; border-radius: 4; font-size: 18 }
  }
}

# ============================================================
# FRONTEND
# ============================================================
frontend: "FRONTEND\nNext.js 14 | TypeScript" {
  style: {
    fill: "#0D1B2A"
    stroke: "#00BCD4"
    font-color: "#E0F7FA"
    border-radius: 10
    stroke-width: 2
    font-size: 22
  }
  grid-rows: 3
  grid-columns: 1
  grid-gap: 2

  a: "Dashboard" {
    style: { fill: "#1A2D3D"; stroke: "#00ACC1"; font-color: "#B2EBF2"; border-radius: 4; font-size: 18 }
  }
  b: "Detailansichten" {
    style: { fill: "#1A2D3D"; stroke: "#00ACC1"; font-color: "#B2EBF2"; border-radius: 4; font-size: 18 }
  }
  c: "Export" {
    style: { fill: "#1A2D3D"; stroke: "#00ACC1"; font-color: "#B2EBF2"; border-radius: 4; font-size: 18 }
  }
}

# ============================================================
# CI/CD (top)
# ============================================================
cicd: "CI/CD" {
  style: {
    fill: "#1A1A2E"
    stroke: "#5C6BC0"
    font-color: "#C5CAE9"
    border-radius: 10
    stroke-width: 2
    font-size: 22
  }
  grid-rows: 2
  grid-columns: 2
  grid-gap: 2

  a: "GitHub Actions" {
    style: { fill: "#252547"; stroke: "#7986CB"; font-color: "#C5CAE9"; border-radius: 4; font-size: 18 }
  }
  b: "Docker / ghcr.io" {
    style: { fill: "#252547"; stroke: "#7986CB"; font-color: "#C5CAE9"; border-radius: 4; font-size: 18 }
  }
  c: "6 Pipelines" {
    style: { fill: "#252547"; stroke: "#7986CB"; font-color: "#C5CAE9"; border-radius: 4; font-size: 18 }
  }
  d: "836+ Tests" {
    style: { fill: "#252547"; stroke: "#7986CB"; font-color: "#C5CAE9"; border-radius: 4; font-size: 18 }
  }
}

# ============================================================
# CONNECTIONS (left to right flow)
# ============================================================
external -> database: ETL {
  style: { stroke: "#78909C"; stroke-width: 2; stroke-dash: 5; font-color: "#B0BEC5"; font-size: 18 }
}
database -> services: SQL / asyncpg {
  style: { stroke: "#FFA726"; stroke-width: 2; font-color: "#FFCC80"; font-size: 18 }
}
services -> gateway: gRPC / Protobuf {
  style: { stroke: "#7E57C2"; stroke-width: 2; font-color: "#B39DDB"; font-size: 18 }
}
gateway -> frontend: HTTP / JSON {
  style: { stroke: "#26A69A"; stroke-width: 2; font-color: "#80CBC4"; font-size: 18 }
}

cicd -> frontend: {
  style: { stroke: "#5C6BC0"; stroke-width: 1; stroke-dash: 5 }
}
cicd -> gateway: {
  style: { stroke: "#5C6BC0"; stroke-width: 1; stroke-dash: 5 }
}
cicd -> services: {
  style: { stroke: "#5C6BC0"; stroke-width: 1; stroke-dash: 5 }
}
