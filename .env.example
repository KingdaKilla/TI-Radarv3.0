# ============================================================
# TI-Radar — Umgebungskonfiguration
# ============================================================
# Diese Datei nach .env kopieren und Werte eintragen:
#   cp .env.example .env
# ============================================================

# --- Datenbank ---
POSTGRES_DB=ti_radar
POSTGRES_USER=tip_admin
POSTGRES_PASSWORD=          # Sicheres Passwort waehlen

# Datenbank-Speicherort (externes Laufwerk empfohlen)
# Windows: D:/ti-radar-db  |  Linux: /mnt/external/ti-radar-db
TI_RADAR_DB_PATH=

# --- Externe APIs ---
# EPO Open Patent Services (kostenlose Registrierung)
# Registrierung: https://developers.epo.org/ -> "My Apps" -> App erstellen
EPO_OPS_CONSUMER_KEY=
EPO_OPS_CONSUMER_SECRET=

# --- Bulk-Daten (optional, nur fuer Erst-Import) ---
# EPO DOCDB: https://www.epo.org/searching-for-patents/data/bulk-data-sets/docdb.html
# CORDIS: https://data.europa.eu/data/datasets/cordisref-data
# EPO_BULK_PATH=./data/bulk/EPO
# CORDIS_BULK_PATH=./data/bulk/CORDIS

# --- Service-Datenbank-Passwoerter (Defaults fuer lokale Entwicklung) ---
# Jeder Service hat einen eigenen DB-User. Die Defaults aus docker-compose.yml
# funktionieren fuer lokale Entwicklung. Fuer Produktion hier aendern.
# SVC_LANDSCAPE_PW=svc_landscape_pw
# SVC_MATURITY_PW=svc_maturity_pw
# ... (siehe deploy/docker-compose.yml fuer alle Service-Passwoerter)

# --- Service-Konfiguration (Defaults funktionieren out-of-the-box) ---
ORCHESTRATOR_PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Monitoring (optional) ---
GRAFANA_ADMIN_PASSWORD=admin
