# ============================================================
# TI-Radar — Umgebungskonfiguration
# ============================================================
# Diese Datei nach .env kopieren und Werte eintragen:
#   cp .env.example .env
# ============================================================

# --- Datenbank (PFLICHT) ---
POSTGRES_DB=ti_radar
POSTGRES_USER=tip_admin
POSTGRES_PASSWORD=          # PFLICHT: Sicheres Passwort wählen

# --- Externe APIs (optional, erhöhen Rate-Limits) ---
# EPO Open Patent Services (kostenlose Registrierung)
# Registrierung: https://developers.epo.org/ -> "My Apps" -> App erstellen
EPO_OPS_CONSUMER_KEY=
EPO_OPS_CONSUMER_SECRET=

# OpenAIRE (erhöht Rate-Limits von 60 auf 7200 req/h)
# Registrierung: https://services.openaire.eu/
# Ohne Token wird die öffentliche API genutzt (reicht für normale Nutzung).
OPENAIRE_ACCESS_TOKEN=
OPENAIRE_REFRESH_TOKEN=

# Semantic Scholar (erhöht Rate-Limit von 100 auf 1000 req/s)
# Registrierung: https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# --- Bulk-Daten (optional, nur für Erst-Import großer Datensätze) ---
# EPO DOCDB: https://www.epo.org/searching-for-patents/data/bulk-data-sets/docdb.html
# CORDIS: https://data.europa.eu/data/datasets/cordisref-data
# EPO_BULK_PATH=./data/bulk/EPO
# CORDIS_BULK_PATH=./data/bulk/CORDIS

# --- Service-Datenbank-Passwörter (Defaults für lokale Entwicklung) ---
# Jeder Microservice hat einen eigenen DB-User mit minimalen Rechten.
# Die Defaults funktionieren für lokale Entwicklung. Für Produktion ändern.
# SVC_LANDSCAPE_PW=svc_landscape_pw
# SVC_MATURITY_PW=svc_maturity_pw
# SVC_COMPETITIVE_PW=svc_competitive_pw
# SVC_FUNDING_PW=svc_funding_pw
# SVC_CPC_FLOW_PW=svc_cpc_flow_pw
# SVC_GEOGRAPHIC_PW=svc_geographic_pw
# SVC_RESEARCH_IMPACT_PW=svc_research_impact_pw
# SVC_TEMPORAL_PW=svc_temporal_pw
# SVC_TECH_CLUSTER_PW=svc_tech_cluster_pw
# SVC_ACTOR_TYPE_PW=svc_actor_type_pw
# SVC_PATENT_GRANT_PW=svc_patent_grant_pw
# SVC_EUROSCIVOC_PW=svc_euroscivoc_pw
# SVC_PUBLICATION_PW=svc_publication_pw
# SVC_EXPORT_PW=svc_export_pw

# --- Service-Konfiguration (Defaults funktionieren out-of-the-box) ---
ORCHESTRATOR_PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# --- Import Scheduler (woechentlicher Bulk-Import) ---
# Cron-Ausdruck: Minute Stunde Tag Monat Wochentag (Standard: Sonntag 02:00 UTC)
IMPORT_SCHEDULE=0 2 * * 0
SCHEDULER_ENABLED=true
# SCHEDULER_TIMEZONE=UTC

# --- API Delta-Updates (taeglich, EPO OPS + CORDIS Live-APIs) ---
# API-Daten ueberschreiben Bulk-Daten (ON CONFLICT DO UPDATE).
# Bulk = initiales Setup, APIs = primaere laufende Datenquelle.
API_DELTA_SCHEDULE=0 3 * * *
API_DELTA_LOOKBACK_DAYS=30
EPO_OPS_ENABLED=true
EPO_OPS_TIMEOUT_S=15.0
EPO_OPS_RATE_LIMIT_RPM=200
CORDIS_API_ENABLED=true
CORDIS_API_TIMEOUT_S=15.0
CORDIS_API_RATE_LIMIT_RPM=30

# --- GLEIF LEI Lookup (Actor-Type-Service, kostenlos) ---
GLEIF_ENABLED=true

# --- Import-Service Absicherung (optional) ---
# Ohne Key: MVP-Modus (kein Auth). Fuer Produktion: starkes Secret setzen.
# TI_RADAR_ADMIN_KEY=

# --- Monitoring (optional, nur mit --profile monitoring) ---
GRAFANA_ADMIN_PASSWORD=admin
PGADMIN_PASSWORD=admin

# ==== v3.5.0: LLM-Feature (Panel-Analyse) ====
# Pflicht bei Default-Provider "gemini". Key erzeugen:
#   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optionale Alternativen (nur wenn LLM_PROVIDER=anthropic|openai gesetzt ist):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL_NAME=gemini-2.0-flash

# ==== v3.6.0: RAG-Chat + Embedding ====
# Default: lokales sentence-transformers-Model (intfloat/multilingual-e5-small,
# ~230 MB, wird beim ersten Start aus HuggingFace geladen und im hf_cache-Volume
# persistiert). Alternative: "remote" + TEI_URL fuer dedizierten GPU-Pod.
EMBEDDING_PROVIDER=local
EMBEDDING_DEVICE=cpu               # wechsle auf "cuda" falls GPU vorhanden

# ==== v3.6.0: Faithfulness-Guard (optional, aus by default) ====
# Pruefung der LLM-Antwort gegen Kontext-Dokumente (zusaetzlicher API-Call).
FAITHFULNESS_ENABLED=false
FAITHFULNESS_MODEL=gemini-2.0-flash
FAITHFULNESS_THRESHOLD=PARTIAL
