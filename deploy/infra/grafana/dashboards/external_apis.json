      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 12,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Externe API Services — Fehlerrate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(grpc_calls_total{uc_service=\"landscape\", status!=\"success\"}[5m])) / sum(rate(grpc_calls_total{uc_service=\"landscape\"}[5m]))",
          "legendFormat": "landscape (OpenAIRE)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(grpc_calls_total{uc_service=\"research_impact\", status!=\"success\"}[5m])) / sum(rate(grpc_calls_total{uc_service=\"research_impact\"}[5m]))",
          "legendFormat": "research_impact (Semantic Scholar)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(grpc_calls_total{uc_service=\"competitive\", status!=\"success\"}[5m])) / sum(rate(grpc_calls_total{uc_service=\"competitive\"}[5m]))",
          "legendFormat": "competitive (GLEIF)",
